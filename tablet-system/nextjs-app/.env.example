# Optional — if set, API routes proxy to the Express backend
BACKEND_URL=http://localhost:4000
DRIVER_TOKEN=replace-with-driver-token

# Optional — customer data endpoint for rebook page
NEXT_PUBLIC_API_URL=http://localhost:4000

# Public app URL — used to generate rebook links in SMS messages
NEXT_PUBLIC_APP_URL=https://synergyluxlimodfw.github.io

# Twilio SMS (leave blank to use console.log stub)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
