# Database
DATABASE_URL=postgresql://user:password@localhost:5432/synergylux

# Mapbox (for passenger experience map — uses Static Images API, no JS required)
# Get a free token at https://mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=

# NextAuth
NEXTAUTH_SECRET=replace-with-a-random-32-char-secret
NEXTAUTH_URL=http://localhost:3000

# Optional — if set, API routes proxy to the Express backend
BACKEND_URL=http://localhost:4000
DRIVER_TOKEN=replace-with-driver-token

# Optional — customer data endpoint for rebook page
NEXT_PUBLIC_API_URL=http://localhost:4000

# Public app URL — used to generate rebook links in SMS messages
NEXT_PUBLIC_APP_URL=https://synergyluxlimodfw.github.io

# Twilio SMS (leave blank to use console.log stub)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
